<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/video_card_margin"
    android:clickable="true"
    android:focusable="true"
    android:stateListAnimator="@animator/blbl_focus_scale"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/blblFocusStrokeColor"
    app:strokeWidth="2dp"
    app:cardUseCompatPadding="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_cover"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="16:9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_cover"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_cover_fade_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.8" />

            <View
                android:id="@+id/v_cover_fade"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/video_card_bottom_fade"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/guideline_cover_fade_top" />

            <View
                android:id="@+id/v_action_scrim"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/bg_video_card_action_scrim"
                android:importantForAccessibility="no"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/ll_actions"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/video_card_action_group_margin_h"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <FrameLayout
                    android:id="@+id/btn_action_watch_later"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/video_card_action_button_height"
                    android:layout_weight="1"
                    android:background="@drawable/bg_video_card_action_button"
                    android:clickable="true"
                    android:focusable="false"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:id="@+id/iv_action_watch_later"
                        android:layout_width="@dimen/video_card_action_icon_watch_later_size"
                        android:layout_height="@dimen/video_card_action_icon_watch_later_size"
                        android:layout_gravity="center"
                        android:contentDescription="@string/video_card_action_watch_later"
                        android:src="@drawable/ic_video_card_watch_later"
                        android:tint="@android:color/white" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btn_action_detail"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/video_card_action_button_height"
                    android:layout_marginStart="@dimen/video_card_action_gap"
                    android:layout_weight="1"
                    android:background="@drawable/bg_video_card_action_button"
                    android:clickable="true"
                    android:focusable="false"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:id="@+id/iv_action_detail"
                        android:layout_width="@dimen/video_card_action_icon_detail_size"
                        android:layout_height="@dimen/video_card_action_icon_detail_size"
                        android:layout_gravity="center"
                        android:contentDescription="@string/video_card_action_open_detail"
                        android:src="@drawable/ic_player_detail"
                        android:tint="@android:color/white" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btn_action_up"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/video_card_action_button_height"
                    android:layout_marginStart="@dimen/video_card_action_gap"
                    android:layout_weight="1"
                    android:background="@drawable/bg_video_card_action_button"
                    android:clickable="true"
                    android:focusable="false"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:id="@+id/iv_action_up"
                        android:layout_width="@dimen/video_card_action_icon_up_size"
                        android:layout_height="@dimen/video_card_action_icon_up_size"
                        android:layout_gravity="center"
                        android:contentDescription="@string/video_card_action_open_up"
                        android:src="@drawable/ic_player_up"
                        android:tint="@android:color/white" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btn_action_dismiss"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/video_card_action_button_height"
                    android:layout_marginStart="@dimen/video_card_action_gap"
                    android:layout_weight="1"
                    android:background="@drawable/bg_video_card_action_button"
                    android:clickable="true"
                    android:focusable="false"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:id="@+id/iv_action_dismiss"
                        android:layout_width="@dimen/video_card_action_icon_dismiss_size"
                        android:layout_height="@dimen/video_card_action_icon_dismiss_size"
                        android:layout_gravity="center"
                        android:contentDescription="@string/video_card_action_not_interested"
                        android:src="@drawable/ic_video_card_delete"
                        android:tint="@android:color/white" />
                </FrameLayout>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_watch"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="@dimen/video_card_progress_bar_height"
                android:max="1000"
                android:progress="0"
                android:progressDrawable="@drawable/progress_video_card_watch"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_cover_left_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/video_card_text_margin"
                android:shadowColor="#CC000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:textColor="@color/blbl_text_on_media"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_progress_left"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/video_card_text_margin"
                android:paddingHorizontal="@dimen/video_card_duration_padding_h"
                android:paddingVertical="@dimen/video_card_duration_padding_v"
                android:shadowColor="#CC000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:textColor="@color/blbl_text_on_media"
                android:textSize="@dimen/video_card_stat_text_size"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/tv_charge_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/video_card_text_margin"
                android:background="@drawable/bg_pgc_access_badge"
                android:gravity="center"
                android:paddingHorizontal="@dimen/video_card_duration_padding_h"
                android:paddingVertical="@dimen/video_card_duration_padding_v"
                android:text="@string/badge_charging"
                android:textColor="@android:color/white"
                android:textSize="@dimen/video_card_duration_text_size"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/video_card_text_margin"
                android:paddingHorizontal="@dimen/video_card_duration_padding_h"
                android:paddingVertical="@dimen/video_card_duration_padding_v"
                android:shadowColor="#CC000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:textColor="@color/blbl_text_on_media"
                android:textSize="@dimen/video_card_duration_text_size"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_progress_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/video_card_text_margin"
                android:paddingHorizontal="@dimen/video_card_duration_padding_h"
                android:paddingVertical="@dimen/video_card_duration_padding_v"
                android:shadowColor="#CC000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:textColor="@color/blbl_text_on_media"
                android:textSize="@dimen/video_card_duration_text_size"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/ll_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/video_card_text_margin"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/video_card_duration_padding_h"
                android:paddingVertical="@dimen/video_card_duration_padding_v"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageView
                    android:id="@+id/iv_stat_play"
                    android:layout_width="@dimen/video_card_stat_icon_size"
                    android:layout_height="@dimen/video_card_stat_icon_size"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_stat_play" />

                <TextView
                    android:id="@+id/tv_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:shadowColor="#CC000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2"
                    android:textColor="@color/blbl_text_on_media"
                    android:textSize="@dimen/video_card_stat_text_size" />

                <ImageView
                    android:id="@+id/iv_stat_danmaku"
                    android:layout_width="@dimen/video_card_stat_icon_size"
                    android:layout_height="@dimen/video_card_stat_icon_size"
                    android:layout_marginStart="10dp"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_stat_danmaku" />

                <TextView
                    android:id="@+id/tv_danmaku"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:shadowColor="#CC000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2"
                    android:textColor="@color/blbl_text_on_media"
                    android:textSize="@dimen/video_card_stat_text_size" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="@dimen/video_card_text_margin"
            android:ellipsize="end"
            android:lines="2"
            android:maxLines="2"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/video_card_title_text_size"
            app:layout_constraintBottom_toTopOf="@id/ll_subtitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_default="wrap"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cl_cover" />

        <LinearLayout
            android:id="@+id/ll_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/video_card_text_margin"
            android:layout_marginBottom="@dimen/video_card_text_margin"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title">

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="@dimen/video_card_subtitle_text_size" />

            <TextView
                android:id="@+id/tv_pubdate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="@dimen/video_card_subtitle_text_size" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
