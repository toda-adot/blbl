<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Player OSD sizing: resolved via ThemeOverlay so UI can be tuned by XML (S/M/L + TV/normal). -->
    <attr name="playerOsdButtonTargetSize" format="dimension" />
    <attr name="playerOsdPadTransport" format="dimension" />
    <attr name="playerOsdPadNormal" format="dimension" />
    <attr name="playerOsdPadSmall" format="dimension" />
    <attr name="playerOsdGap" format="dimension" />

    <!-- Theme preset support (non-player scope). -->
    <!-- Some layouts rely on Material's `?attr/colorBackground`. Define it locally for safety. -->
    <attr name="colorBackground" format="color" />
    <attr name="blblContentBackground" format="reference|color" />
    <attr name="blblAccent" format="color" />
    <attr name="blblAccentContainer" format="color" />
    <attr name="blblAccentWeak" format="color" />
    <attr name="blblAccentPressed" format="color" />

    <attr name="blblFocusBgRound" format="reference" />
    <attr name="blblFocusListSelectorRound" format="reference" />
    <attr name="blblFocusStrokeColor" format="reference|color" />
    <attr name="blblFocusStrokeFocusOnlyColor" format="reference|color" />
</resources>
